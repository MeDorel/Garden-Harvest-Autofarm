		Status.Text = "Status: Idle"
		Timer.Text = "Next harvest: --"
	end
end)

------------------------------------------------
-- // MAIN LOOP
------------------------------------------------
task.spawn(function()
	while loopRunning do
		if autoEnabled then
			RunCycle()

			-- Wait 50s before next harvest
			for i = 50, 1, -1 do
				if not autoEnabled or not loopRunning then break end
				Timer.Text = "Next harvest: " .. i .. "s"
				task.wait(1)
			end
		else
			task.wait(0.5)
		end
	end
end)
