local lightingStates = {
    day = true,
    nofog = true
}

local function applyDay()
    if lightingStates.day then
        Lighting.ClockTime = 0
        Lighting.Brightness = 0.7
        Lighting.Ambient = Color3.fromRGB(150, 150, 150)
        Lighting.OutdoorAmbient = Color3.fromRGB(120, 120, 120)
    end
end

local function applyNoFog()
    if lightingStates.nofog then
        Lighting.FogEnd = 100000
        Lighting.FogStart = 0
        for _, v in pairs(Lighting:GetDescendants()) do
            if v:IsA("Atmosphere") then
                v:Destroy()
            end
        end
    end
end

applyDay()
applyNoFog()

Lighting:GetPropertyChangedSignal("ClockTime"):Connect(applyDay)
Lighting:GetPropertyChangedSignal("Brightness"):Connect(applyDay)
Lighting:GetPropertyChangedSignal("Ambient"):Connect(applyDay)
Lighting:GetPropertyChangedSignal("OutdoorAmbient"):Connect(applyDay)
Lighting:GetPropertyChangedSignal("FogEnd"):Connect(applyNoFog)
Lighting:GetPropertyChangedSignal("FogStart"):Connect(applyNoFog)

Lighting.DescendantAdded:Connect(function(v)
    if lightingStates.nofog and v:IsA("Atmosphere") then
        v:Destroy()
    end
end)

task.spawn(function()
    while true do
        applyDay()
        applyNoFog()
        task.wait(0.2)
    end
end)

