-- // LOGIC
------------------------------------------------
local HarvestRemote = LocalPlayer:WaitForChild("Systems"):WaitForChild("Harvest_Crops")
local autoEnabled = false
local loopRunning = true

local function FindPlayerPlot()
	local PlotsFolder = workspace:WaitForChild("Plots")
	for i = 1, 6 do
		local plot = PlotsFolder:FindFirstChild("Plot_" .. i)
		if plot then
			local ok, name = pcall(function()
				return plot.Model.PlayerDisplay.BillboardGui.Username.Text
			end)
			if ok and name == LocalPlayer.DisplayName then
				return plot, "Plot_" .. i
			end
		end
	end
	return nil, nil
end

local function HarvestAllCrops(plotsFolder)
	local cropRefs = {}
	local seen = {}

	local function searchForCrops(parent)
		for _, child in pairs(parent:GetChildren()) do
			if child.Name == "Crop" and not seen[child] then
				seen[child] = true
				table.insert(cropRefs, child)
			end
			searchForCrops(child)
		end
	end

	searchForCrops(plotsFolder)
	Status.Text = "Status: Found " .. #cropRefs .. " crops, harvesting..."

	if #cropRefs == 0 then
		pcall(function() HarvestRemote:FireServer({}) end)
		Status.Text = "Status: Fired fruit harvest"
		return 0
	end

	local ok, err = pcall(function()
		HarvestRemote:FireServer(cropRefs)
	end)

	Status.Text = ok
		and "Status: Harvested " .. #cropRefs .. " crops"
		or "Status: Error - " .. tostring(err)

	return #cropRefs
end

local function tpTo(part)
	local char = LocalPlayer.Character
	if char and char:FindFirstChild("HumanoidRootPart") and part then
		char.HumanoidRootPart.CFrame = part.CFrame + Vector3.new(0, 3, 0)
	end
end

local function RunCycle()
	local playerPlot, plotName = FindPlayerPlot()
	if not playerPlot then
		Status.Text = "Status: Plot not found!"
		return
	end

	-- Step 1: TP home
	Status.Text = "Status: Going home..."
	Timer.Text = "Going home..."
	local tpPart = playerPlot.Model:FindFirstChild("TP_Part")
	if tpPart then
		local inner = tpPart:FindFirstChild("TP_Part")
		if inner then tpTo(inner) end
	end
	task.wait(1)

	-- Step 2: Harvest
	Status.Text = "Status: Harvesting..."
	Timer.Text = "Harvesting..."
	local plotsFolder = playerPlot:WaitForChild("Model"):WaitForChild("Plots")
	local count = HarvestAllCrops(plotsFolder)
	task.wait(1)

	-- Step 3: Wait 50s before selling
	for i = 50, 1, -1 do
		if not autoEnabled or not loopRunning then return end
		Status.Text = "Status: Harvested " .. count .. " crops"
		Timer.Text = "Selling in: " .. i .. "s"
		task.wait(1)
	end

	-- Step 4: Sell
	Status.Text = "Status: Going to sell..."
	Timer.Text = "Selling..."
	local sellMain = playerPlot.Model:FindFirstChild("Sell_Main")
	if sellMain then
		local sellCrops = sellMain:FindFirstChild("Sell_Crops")
		if sellCrops then tpTo(sellCrops) end
	end
	task.wait(2)

	-- Step 5: Bonus money
	Status.Text = "Status: Collecting bonus..."
	Timer.Text = "Collecting bonus..."
	local bonusMoney = playerPlot.Model:FindFirstChild("Bonus_Money")
	if bonusMoney then
		local bonusMain = bonusMoney:FindFirstChild("Main")
		if bonusMain then tpTo(bonusMain) end
	end
	task.wait(2)

	-- Step 6: TP back home
	Status.Text = "Status: Returning home..."
	Timer.Text = "Going home..."
	if tpPart then
		local inner = tpPart:FindFirstChild("TP_Part")
		if inner then tpTo(inner) end
	end
	task.wait(1)

	Status.Text = "Status: Cycle done! " .. count .. " crops harvested"
end

