local function FindPlayerPlot()
    local PlotsFolder = workspace:WaitForChild("Plots")
    local PlayerDisplayName = LocalPlayer.DisplayName
    
    for i = 1, 6 do
        local plotName = "Plot_" .. i
        local plot = PlotsFolder:FindFirstChild(plotName)
        
        if plot then
            local success, username = pcall(function()
                return plot.Model.PlayerDisplay.BillboardGui.Username.Text
            end)
            
            if success and username == PlayerDisplayName then
                return plot, plotName
            end
        end
    end
    
    return nil, nil
end

local function HarvestAndSell()
    canStartTimer = false
    local playerPlot, plotName = FindPlayerPlot()
    if not playerPlot then
        Status.Text = "Status: Plot not found!"
        return
    end
    
    Status.Text = "Status: Harvesting crops..."
    Timer.Text = "Harvesting..."
    
    local plotsFolder = playerPlot:WaitForChild("Model"):WaitForChild("Plots")
    local harvestedCount = 0
    
    for _, cropPlot in pairs(plotsFolder:GetChildren()) do
        local crop = cropPlot:FindFirstChild("Crop")
        if crop then
            pcall(function()
                local args = {{crop}}
                LocalPlayer:WaitForChild("Systems"):WaitForChild("Harvest_Crops"):FireServer(unpack(args))
                harvestedCount = harvestedCount + 1
            end)
            wait(0.4)
        end
    end
    
    wait(1)
    
    Status.Text = "Status: Going to shop..."
    Timer.Text = "Going to shop..."
    
    local sellCrops = workspace.Plots[plotName].Model:FindFirstChild("Sell_Main")
    if sellCrops then
        sellCrops = sellCrops:FindFirstChild("Sell_Crops")
        if sellCrops then
            LocalPlayer.Character.HumanoidRootPart.CFrame = sellCrops.CFrame
        end
    end
    
    wait(2)
    
    Status.Text = "Status: Collecting bonus..."
    Timer.Text = "Collecting bonus..."
    
    local bonusMoney = workspace.Plots[plotName].Model:FindFirstChild("Bonus_Money")
    if bonusMoney then
        local bonusMain = bonusMoney:FindFirstChild("Main")
        if bonusMain then
            LocalPlayer.Character.HumanoidRootPart.CFrame = bonusMain.CFrame
        end
    end
    
    wait(2)
    
    Status.Text = "Status: Returning to plot..."
    Timer.Text = "Returning..."
    
    local tpPart = workspace.Plots[plotName].Model:FindFirstChild("TP_Part")
    if tpPart then
        local tpPartPart = tpPart:FindFirstChild("TP_Part")
        if tpPartPart then
            LocalPlayer.Character.HumanoidRootPart.CFrame = tpPartPart.CFrame
        end
    end
    
    wait(1)
    
    Status.Text = "Status: Collected " .. harvestedCount .. " crops\nWaiting for next cycle..."
    canStartTimer = true
end

ToggleButton.MouseButton1Click:Connect(function()
    autoCollectEnabled = not autoCollectEnabled
    
    if autoCollectEnabled then
        ToggleButton.Text = "STOP"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(60, 220, 100)
        ToggleStroke.Thickness = 2
        HarvestAndSell()
    else
        ToggleButton.Text = "START"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
        ToggleStroke.Thickness = 0
        Status.Text = "Status: Idle"
        Timer.Text = "Next cycle: --"
        canStartTimer = false
    end
end)

spawn(function()
    while loopRunning do
        if autoCollectEnabled and loopRunning and canStartTimer then
            for i = 60, 0, -1 do
                if not autoCollectEnabled or not loopRunning or not canStartTimer then break end
                Timer.Text = "Next cycle: " .. i .. "s"
                wait(1)
            end
            if autoCollectEnabled and loopRunning then
                HarvestAndSell()
            end
        else
            wait(1)
        end
    end
end)
